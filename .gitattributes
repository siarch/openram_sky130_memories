# Default behavior: let Git detect text files.
* text=auto

# Cross-platform source and document files should stay LF.
*.py text eol=lf
*.sh text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.jsonl text eol=lf
*.tcl text eol=lf
*.csv text eol=lf
*.sp text eol=lf
*.lib text eol=lf

# Windows-native shell scripts should stay CRLF.
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary artifacts should never be normalized.
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.zip binary
*.gz binary
*.7z binary
*.tar binary
*.tgz binary
*.gds binary
